<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <EditText
            android:id="@+id/customer_name_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/customer_name"
            android:inputType="textPersonName"
            android:maxLines="1" />

        <EditText
            android:id="@+id/caller_number_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/caller_number"
            android:inputType="phone"
            android:maxLines="1" />

        <EditText
            android:id="@+id/callee_number_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/callee_number"
            android:inputType="phone"
            android:maxLines="1" />

        <EditText
            android:id="@+id/begin_time_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/begin_time"
            android:inputType="text"
            android:maxLines="1" />

        <EditText
            android:id="@+id/end_time_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/end_time"
            android:inputType="text"
            android:maxLines="1" />

        <Button
            android:id="@+id/add_call_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/add_call" />

        <Button
            android:id="@+id/pretty_print_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/show_pretty_bill" />

        <EditText
            android:id="@+id/search_begin_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="@string/search_begin"
            android:inputType="text"
            android:maxLines="1" />

        <EditText
            android:id="@+id/search_end_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/search_end"
            android:inputType="text"
            android:maxLines="1" />

        <Button
            android:id="@+id/search_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/search_calls" />

        <TextView
            android:id="@+id/results_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/results_title"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/results_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="#11000000"
            android:padding="12dp"
            android:textIsSelectable="true" />

    </LinearLayout>
</ScrollView>
